  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "start:sse": "node build/index.js --sse",
    "dev": "tsc -w & nodemon build/index.js",
    "dev:sse": "tsc -w & nodemon build/index.js --sse",
    "lint": "eslint src/**/*.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
